---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<MainLayout title={entry.data.title}>
  <div class="max-w-7xl mx-auto py-12 md:py-20 px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <div
        class="w-full aspect-square sticky top-28 rounded-[32px] overflow-hidden shadow-2xl border border-stone-100 bg-white"
      >
        <img
          src={entry.data.image}
          alt={entry.data.title}
          class="w-full h-full object-cover transition duration-700 hover:scale-105"
          onerror="this.src='https://placehold.co/1200x1200?text=YSTV+Product'"
        />
      </div>

      <div class="space-y-8">
        <nav
          class="text-xs text-stone-400 font-bold uppercase tracking-[0.2em]"
        >
          <a href="/san-pham" class="hover:text-amber-700 transition"
            >Sản phẩm</a
          >
          <span class="mx-2 text-stone-300">/</span>
          <span class="text-amber-700">{entry.data.category}</span>
        </nav>

        <h1
          class="text-4xl md:text-5xl font-serif font-bold text-stone-800 leading-tight"
        >
          {entry.data.title}
        </h1>

        <p class="text-3xl font-bold text-amber-700">
          {entry.data.price || "Đang cập nhật"}
        </p>

        <div
          class="grid grid-cols-2 gap-y-6 gap-x-8 border-y border-stone-100 py-8"
        >
          <div class="text-sm">
            <span
              class="font-bold block text-stone-400 uppercase text-[10px] mb-1 tracking-wider"
              >Trọng lượng:</span
            >
            <span class="text-stone-700 font-medium"
              >{entry.data.weight || "Đang cập nhật"}</span
            >
          </div>
          <div class="text-sm">
            <span
              class="font-bold block text-stone-400 uppercase text-[10px] mb-1 tracking-wider"
              >Chứng nhận:</span
            >
            <span class="text-stone-700 font-medium"
              >{entry.data.certification || "Đang cập nhật"}</span
            >
          </div>
          <div class="text-sm col-span-2">
            <span
              class="font-bold block text-stone-400 uppercase text-[10px] mb-1 tracking-wider"
              >Thành phần:</span
            >
            <span class="text-stone-700 font-medium leading-relaxed"
              >{entry.data.ingredients || "Đang cập nhật"}</span
            >
          </div>
        </div>

        <div
          class="prose prose-stone max-w-none text-stone-600 leading-relaxed"
        >
          <Content />
        </div>

        <div
          class="bg-stone-50 p-8 rounded-[24px] border border-stone-100 space-y-4"
        >
          <h4 class="font-bold text-stone-800 flex items-center gap-2">
            <span class="text-amber-700">●</span> Hướng dẫn sử dụng:
          </h4>
          <p class="text-sm italic text-stone-500 leading-relaxed">
            {entry.data.usage}
          </p>
        </div>

        <a
          href="https://zalo.me/0973080694"
          class="block text-center bg-stone-900 text-white py-5 rounded-2xl font-bold text-lg hover:bg-amber-800 transition shadow-xl transform hover:-translate-y-1 active:scale-95"
        >
          Tư vấn sỉ & lẻ qua Zalo
        </a>
      </div>
    </div>
  </div>
</MainLayout>
