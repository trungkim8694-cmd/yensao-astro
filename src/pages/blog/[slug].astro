---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

// 1. Tạo đường dẫn động cho tất cả bài viết tiếng Việt
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

// 2. Lấy dữ liệu bài viết từ props
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<MainLayout title={entry.data.title}>
  <article class="py-20 px-6 max-w-4xl mx-auto">
    <header class="mb-12 text-center">
      <nav class="text-sm font-bold text-amber-700 uppercase tracking-widest mb-4">
        <a href="/blog">Kiến thức Yến Sào</a>
      </nav>
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-stone-800 mb-6 leading-tight">
        {entry.data.title}
      </h1>
      <p class="text-stone-400 italic">Ngày đăng: {entry.data.pubDate.toLocaleDateString('vi-VN')}</p>
    </header>

    <img src={entry.data.image} alt={entry.data.title} class="w-full h-[400px] object-cover rounded-3xl shadow-2xl mb-12" />

    <div class="prose prose-stone lg:prose-xl max-w-none text-stone-700 leading-relaxed prose-headings:font-serif prose-headings:text-stone-800 prose-amber">
      <Content />
    </div>

    <footer class="mt-16 pt-8 border-t border-stone-100 flex justify-between items-center">
      <a href="/blog" class="text-stone-500 hover:text-amber-700 font-bold transition">← Quay lại danh sách</a>
      <div class="flex gap-4">
        <span class="text-sm text-stone-400">Chia sẻ:</span>
        <div class="flex gap-2 text-stone-600 font-bold">Zalo / Facebook</div>
      </div>
    </footer>
  </article>
</MainLayout>