---
import MainLayout from "../../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const products = await getCollection("zh-products");
  return products.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<MainLayout title={entry.data.title} lang="zh">
  <div class="max-w-7xl mx-auto py-12 md:py-20 px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <div
        class="w-full aspect-square sticky top-28 rounded-[32px] overflow-hidden shadow-2xl border border-stone-100 bg-white"
      >
        <img
          src={entry.data.image}
          alt={entry.data.title}
          class="w-full h-full object-cover transition duration-700 hover:scale-105"
          onerror="this.src='https://placehold.co/1200x1200?text=YSTV+Product'"
        />
      </div>

      <div class="space-y-8 text-left">
        <nav
          class="text-xs text-stone-400 font-bold uppercase tracking-[0.2em]"
        >
          <a href="/zh/products" class="hover:text-amber-700 transition"
            >燕窝产品</a
          >
          <span class="mx-2 text-stone-300">/</span>
          <span class="text-amber-700">{entry.data.category}</span>
        </nav>

        <h1
          class="text-4xl md:text-5xl font-serif font-bold text-stone-800 leading-tight"
        >
          {entry.data.title}
        </h1>

        <p
          class="text-3xl font-bold text-amber-700 border-b border-stone-100 pb-8"
        >
          {entry.data.price || "咨询价格"}
        </p>

        <div class="grid grid-cols-2 gap-y-6 gap-x-8 py-4">
          <div class="text-sm">
            <span
              class="font-bold block text-stone-400 uppercase text-[10px] mb-1 tracking-wider"
              >产品规格:</span
            >
            <span class="text-stone-700 font-medium">{entry.data.weight}</span>
          </div>
          <div class="text-sm">
            <span
              class="font-bold block text-stone-400 uppercase text-[10px] mb-1 tracking-wider"
              >质量认证:</span
            >
            <span class="text-stone-700 font-medium"
              >{entry.data.certification}</span
            >
          </div>
        </div>

        <div
          class="prose prose-stone max-w-none text-stone-600 border-t border-stone-100 pt-8 leading-relaxed"
        >
          <Content />
        </div>

        <div class="flex flex-col gap-4 pt-8">
          <a
            href="https://zalo.me/0973080694"
            class="bg-stone-900 text-white text-center py-5 rounded-2xl font-bold text-lg hover:bg-amber-800 transition shadow-xl transform hover:-translate-y-1 active:scale-95"
          >
            立即咨询 (WhatsApp / Zalo)
          </a>
          <p
            class="text-center text-xs text-stone-400 uppercase tracking-widest leading-relaxed"
          >
            支持全球发货 | OEM 定制服务 | 100% 天然纯正
          </p>
        </div>
      </div>
    </div>
  </div>
</MainLayout>
