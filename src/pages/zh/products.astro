---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

// Lấy đúng sản phẩm từ bộ sưu tập tiếng Trung
const allProducts = await getCollection("zh-products");
const categories = ["全部", "原味燕盏", "精制燕窝", "即食燕窝", "燕窝礼盒"];
---

<MainLayout title="燕窝产品目录" lang="zh">
  <section class="py-16 px-6 max-w-7xl mx-auto text-left">
    <h1 class="text-4xl font-serif font-bold text-center mb-12 text-stone-800">
      优质产品系列/ Sản phẩm
    </h1>

    <div
      class="flex flex-wrap justify-center gap-4 mb-16"
      id="zh-category-filters"
    >
      {
        categories.map((cat) => (
          <button
            data-category={cat}
            class="zh-filter-btn px-6 py-2 rounded-full border border-stone-200 transition-all font-medium text-sm shadow-sm"
          >
            {cat}
          </button>
        ))
      }
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10" id="zh-product-grid">
      {
        allProducts.map((product) => (
          <div
            class="zh-product-card group bg-white rounded-3xl overflow-hidden border border-stone-100 shadow-sm hover:shadow-md transition-all duration-300"
            data-category={product.data.category}
          >
            <a href={`/zh/products/${product.slug}`}>
              <div class="relative h-72 overflow-hidden bg-stone-100">
                <img
                  src={product.data.image}
                  alt={product.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
                />
                <div class="absolute top-4 left-4 bg-amber-700 text-white text-[10px] px-3 py-1 rounded-full font-bold uppercase">
                  {product.data.category}
                </div>
              </div>

              {/* PHẦN NỘI DUNG ĐÃ ĐƯỢC CHÈN SAO VÀO ĐÚNG VỊ TRÍ */}
              <div class="p-8">
                <div class="flex items-center gap-1 text-amber-500 mb-2">
                  {Array.from({ length: 5 }).map((_, index) => (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill={
                        index < (Number(product.data.rating) || 5)
                          ? "currentColor"
                          : "none"
                      }
                      stroke="currentColor"
                      class="w-4 h-4"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"
                      />
                    </svg>
                  ))}
                  <span class="text-xs text-stone-400 ml-1 font-medium">
                    (5.0)
                  </span>
                </div>

                <h3 class="text-xl font-serif font-bold text-stone-800 mb-4 group-hover:text-amber-700 transition">
                  {product.data.title}
                </h3>

                <div class="flex justify-between items-center border-t border-stone-50 pt-4 mt-2">
                  <span class="text-lg font-bold text-stone-900">
                    {product.data.price}
                  </span>
                  <span class="text-sm font-bold bg-stone-900 text-white px-4 py-2 rounded-xl transition-colors group-hover:bg-amber-700">
                    立即咨询
                  </span>
                </div>
              </div>
            </a>
          </div>
        ))
      }
    </div>
  </section>

  <script>
    const filterBtns = document.querySelectorAll(".zh-filter-btn");
    const productCards = document.querySelectorAll(".zh-product-card");

    function applyFilter(targetCategory: string) {
      filterBtns.forEach((btn) => {
        if (btn.getAttribute("data-category") === targetCategory) {
          btn.classList.add("bg-amber-700", "text-white", "border-amber-700");
        } else {
          btn.classList.remove(
            "bg-amber-700",
            "text-white",
            "border-amber-700",
          );
        }
      });

      productCards.forEach((card) => {
        const itemCat = card.getAttribute("data-category");
        if (targetCategory === "全部" || itemCat === targetCategory) {
          (card as HTMLElement).style.display = "block";
        } else {
          (card as HTMLElement).style.display = "none";
        }
      });
    }

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const cat = btn.getAttribute("data-category") || "全部";
        applyFilter(cat);
      });
    });

    applyFilter("全部");
  </script>
</MainLayout>
