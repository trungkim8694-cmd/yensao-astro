---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

// 1. Tạo đường dẫn động cho tất cả bài viết tiếng Trung
export async function getStaticPaths() {
  const zhBlogEntries = await getCollection('zh-blog');
  return zhBlogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<MainLayout title={entry.data.title} lang="zh">
  <article class="py-20 px-6 max-w-4xl mx-auto text-left">
    <header class="mb-12">
      <nav class="text-sm font-bold text-amber-700 uppercase tracking-widest mb-4">
        <a href="/zh/blog">燕窝百科</a>
      </nav>
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-stone-800 mb-6 leading-tight">
        {entry.data.title}
      </h1>
      <p class="text-stone-400 italic">发布日期: {entry.data.pubDate.toLocaleDateString('zh-CN')}</p>
    </header>

    <img src={entry.data.image} alt={entry.data.title} class="w-full h-[400px] object-cover rounded-3xl shadow-2xl mb-12" />

    <div class="prose prose-stone lg:prose-xl max-w-none text-stone-700 leading-relaxed prose-headings:font-serif prose-headings:text-stone-800 prose-amber">
      <Content />
    </div>

    <div class="mt-16 p-8 bg-stone-900 rounded-3xl text-white">
      <h3 class="text-2xl font-serif font-bold mb-4">寻找高品质燕窝？</h3>
      <p class="text-stone-400 mb-6 text-sm">越南盛旺燕窝提供原产地直供的高品质产品，欢迎咨询批发业务。</p>
      <a href="https://zalo.me/0973080694" class="inline-block bg-amber-600 px-8 py-3 rounded-xl font-bold hover:bg-amber-700 transition">立即在线咨询</a>
    </div>

    <footer class="mt-12">
        <a href="/zh/blog" class="text-stone-500 hover:text-amber-700 font-bold">← 返回百科列表</a>
    </footer>
  </article>
</MainLayout>