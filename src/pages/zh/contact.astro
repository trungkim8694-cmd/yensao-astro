---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="批发咨询 - 联系我们" lang="zh">
  <section class="py-12 md:py-24 px-6 md:px-8 max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-stone-800 mb-4">联系越南盛旺燕窝</h1>
      <p class="text-stone-500">寻找高品质越南燕窝长期合作伙伴</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <div class="rounded-3xl overflow-hidden shadow-2xl h-[400px] bg-stone-200 flex items-center justify-center italic text-stone-400">
        [此处放置您的工厂图片]
      </div>

      <div class="space-y-10">
        <div class="bg-amber-50 p-8 rounded-3xl border-l-8 border-amber-700">
          <h2 class="text-2xl font-bold text-amber-900 mb-4 font-serif">批发代理商政策</h2>
          <p class="text-amber-800 leading-relaxed">
            我们为您提供来自越南富寿省的最优质、最纯净的燕窝。支持大宗贸易、OEM贴牌生产，并提供完整的出口相关文件咨询。
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h4 class="font-bold text-stone-800 mb-2 font-serif text-lg">官方微信 / Zalo</h4>
            <p class="text-amber-700 text-xl font-bold">+84 973 080 694</p>
          </div>
          <div>
            <h4 class="font-bold text-stone-800 mb-2 font-serif text-lg">公司地址</h4>
            <p class="text-stone-600">越南富寿省永祥县河池区</p>
          </div>
        </div>

        <div class="flex gap-4">
          <a href="https://zalo.me/0973080694" class="flex-1 bg-stone-900 text-white text-center py-4 rounded-2xl font-bold hover:bg-amber-700 transition">
            立即在线咨询
          </a>
          <a href="mailto:info@yensaothinhvuong.com" class="flex-1 border border-stone-300 text-center py-4 rounded-2xl font-bold hover:bg-stone-100 transition">
            发送邮件
          </a>
        </div>
      </div>

    </div>
  </section>
</MainLayout>